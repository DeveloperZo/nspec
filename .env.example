# nSpec CLI — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key (primary). Get one at https://console.anthropic.com/
NSPEC_API_KEY=sk-ant-...

# ── Required for Anthropic ────────────────────────────────────────────────────
NSPEC_API_BASE=https://api.anthropic.com/v1
NSPEC_MODEL=claude-sonnet-4-20250514

# ── Optional overrides ────────────────────────────────────────────────────────

# OpenAI-compatible endpoint (if using OpenAI or Ollama instead):
# NSPEC_API_KEY=sk-...
# NSPEC_API_BASE=https://api.openai.com/v1
# NSPEC_MODEL=gpt-4o

# Local Ollama:
# NSPEC_API_KEY=ollama
# NSPEC_API_BASE=http://localhost:11434/v1
# NSPEC_MODEL=llama3

# Specs folder path (relative to cwd). Default: .specs
# NSPEC_SPECS_DIR=.specs
